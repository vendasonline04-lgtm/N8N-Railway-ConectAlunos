# ─── N8N ───────────────────────────────────────────────
# URL pública que o Railway vai gerar para você
N8N_HOST=seu-projeto.up.railway.app
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://seu-projeto.up.railway.app/

# Login do painel N8N (você escolhe)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque-por-senha-forte

# Fuso horário
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# ─── SUPABASE ──────────────────────────────────────────
# Encontre em: Supabase → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# ─── BANCO (N8N usa internamente para salvar fluxos) ───
# Use o banco do próprio Railway (adicione um PostgreSQL lá)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres.railway.internal
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=railway
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=senha-do-postgres-railway

# ─── SEGURANÇA ─────────────────────────────────────────
N8N_ENCRYPTION_KEY=gere-uma-chave-aleatoria-de-32-chars
